# ─── MUYMUY Beauty — Web App Environment Variables ───────────────────────────
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# Para producción, configura estas variables en Vercel:
#   Dashboard → Project → Settings → Environment Variables
#
# NUNCA subas a git un archivo .env con valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# URL del proyecto Supabase (obtenlo en: https://supabase.com/dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon Key pública de Supabase (segura para el cliente, protegida por RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY
