# ─── MUYMUY Beauty — Mobile App Environment Variables ────────────────────────
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# Para producción con EAS Build, configura las variables en eas.json o el
# dashboard de Expo: https://expo.dev → Project → Secrets
#
# NUNCA subas a git un archivo .env con valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# URL del proyecto Supabase
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon Key pública de Supabase
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...YOUR_ANON_KEY
